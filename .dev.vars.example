# Copy this file to .dev.vars and fill in real values.
# .dev.vars is gitignored — never commit it.

# Supabase (same project as vault, service role for server-side access)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic API (for AI course generation)
ANTHROPIC_API_KEY=sk-ant-...

# Learning platform auth
# Generate with: npx tsx scripts/set-master-password.ts
MASTER_PASSWORD_HASH=SALT_BASE64:HASH_BASE64

# Session signing key (32 random bytes, base64-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_HMAC_SECRET=BASE64_32_BYTES
GEMINI_API_KEY=your-gemini-api-key-here

# Tuya smart meter (energy dashboard)
TUYA_ACCESS_ID=your-tuya-access-id
TUYA_ACCESS_SECRET=your-tuya-access-secret
TUYA_DEVICE_ID=your-tuya-device-id

# Energy page gate key (any string; SHA-256 of this is stored in the cookie)
ENERGY_PAGE_KEY=your-energy-page-key

# LINE Messaging API — proactive energy alerts (push to the owner)
# LINE_USER_ID = your userId from the LINE Developers console (or webhook events).
# Optional: alerts are skipped (logged) until set.
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
